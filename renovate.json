{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticPrefixFixDepsChoreOthers",
    ":ignoreUnstable",
    ":automergeDisabled"
  ],
  "schedule": [
    "before 5am on saturday"
  ],
  "timezone": "Asia/Shanghai",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 1,
  "labels": ["dependencies"],
  "baseBranchPatterns": ["main"],
  "rangeStrategy": "bump",
  "branchPrefix": "renovate/",
  "packageRules": [
    {
      "groupName": "All Dependencies",
      "groupSlug": "all-deps",
      "matchPackageNames": ["**"]
    }
  ],
  "vulnerabilityAlerts": {
    "groupName": "All Dependencies",
    "groupSlug": "all-deps"
  },
  "enabledManagers": [
    "gradle",
    "github-actions"
  ]
}
